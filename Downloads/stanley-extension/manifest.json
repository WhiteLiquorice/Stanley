{
  "manifest_version": 3,
  "name": "Project Stanley",
  "version": "1.0.0",
  "description": "Meet Stanley. He handles the boring browser stuff so you don't have to.",
  "permissions": [
    "activeTab",
    "storage",
    "nativeMessaging",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
