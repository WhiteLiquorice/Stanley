rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stanley_users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      function validFreeAccountCreate() {
        return request.resource.data.keys().hasOnly([
          'email', 'status', 'paid', 'runs_used', 'runs_reserved', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.status == 'free'
        && request.resource.data.paid == false
        && request.resource.data.runs_used == 0
        && request.resource.data.runs_reserved == 0;
      }

      function protectedAccountFieldsUnchanged() {
        return request.resource.data.status == resource.data.status
          && request.resource.data.paid == resource.data.paid
          && request.resource.data.runs_used == resource.data.runs_used
          && request.resource.data.runs_reserved == resource.data.runs_reserved;
      }

      allow read: if isOwner();
      allow create: if isOwner() && validFreeAccountCreate();
      allow update: if isOwner() && protectedAccountFieldsUnchanged();
      allow delete: if false;
      
      // Browser-authored product documents. Execution evidence, capability
      // artifacts, approvals, releases, and nested workflow history remain
      // server-owned behind authenticated runner APIs.
      match /workflows/{workflowId} { allow read, write: if isOwner(); }
      match /vault/{secretId} { allow read, write: if isOwner(); }
      match /schedules/{scheduleId} { allow read, write: if isOwner(); }
      match /triggers/{triggerId} { allow read, write: if isOwner(); }
      match /runs/{runId} { allow read: if isOwner(); allow write: if false; }

      match /{document=**} { allow read, write: if false; }
    }
  }
}
