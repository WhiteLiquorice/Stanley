{
  "name": "project-stanley-enterprise",
  "version": "1.0.0",
  "description": "Project Stanley - Enterprise Browser Automation Suite",
  "main": "server.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "start": "node server.js"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@xyflow/react": "^12.11.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase": "^12.15.0",
    "lucide-react": "^1.21.0",
    "node-cron": "^4.6.0",
    "playwright": "^1.42.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "pkg": {
    "assets": [
      "node_modules/playwright-core/package.json",
      "node_modules/playwright-core/browsers.json",
      "node_modules/playwright-core/lib/**/*.js"
    ]
  }
}
